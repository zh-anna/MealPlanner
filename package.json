{
  "name": "mealplanner",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "tokens:build": "node scripts/build-tokens.mjs",
    "preandroid": "npm run tokens:build",
    "preios": "npm run tokens:build",
    "preweb": "npm run tokens:build",
    "start": "node scripts/build-tokens.mjs && expo start",
    "start:clear": "node scripts/build-tokens.mjs && expo start --clear",
    "start:localhost": "node scripts/build-tokens.mjs && expo start --localhost",
    "start:offline": "node scripts/build-tokens.mjs && expo start --offline",
    "watchman:reset": "watchman watch-del-all 2>/dev/null; watchman shutdown-server 2>/dev/null; exit 0",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/geologica": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/material-symbols-rounded": "^0.4.39",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.1",
    "@supabase/supabase-js": "^2.49.8",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.0",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.12"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.20.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
